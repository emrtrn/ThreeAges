{
  "schema": 1,
  "type": "stateTree",
  "blackboard": "assets/starter-content/AI/Boss_Phase_Demo.blackboard.json",
  "parameters": {
    "targetKey": "target",
    "phaseKey": "bossPhase",
    "patrolKey": "currentPatrolTarget",
    "patrolPositionKey": "patrolTargetPosition",
    "attackRange": 3,
    "patrolSpeed": 2.4,
    "chaseSpeed": 5,
    "enragedSpeed": 6.5
  },
  "context": {
    "role": "boss",
    "routine": "phase-combat",
    "arenaTag": "boss-arena"
  },
  "evaluators": [
    {
      "service": "forge.updatePerceptionBlackboard",
      "interval": 0.1,
      "params": {
        "targetKey": "target",
        "hasLineOfSightKey": "hasLineOfSight",
        "lastKnownPositionKey": "lastKnownTargetPosition"
      }
    },
    {
      "service": "forge.updateTargetDistanceBlackboard",
      "interval": 0.05,
      "params": {
        "targetKey": "target",
        "distanceKey": "targetDistance",
        "inRangeKey": "inAttackRange",
        "targetPositionKey": "liveTargetPosition",
        "range": 3
      }
    }
  ],
  "states": [
    {
      "id": "Patrol",
      "tasks": [
        {
          "task": "forge.setBlackboard",
          "params": {
            "key": "bossPhase",
            "value": "patrol"
          }
        },
        {
          "task": "forge.setPatrolTarget",
          "params": {
            "key": "currentPatrolTarget",
            "positionKey": "patrolTargetPosition",
            "mode": "nearest"
          }
        },
        {
          "task": "forge.moveToPatrolTarget",
          "params": {
            "key": "currentPatrolTarget",
            "positionKey": "patrolTargetPosition",
            "speed": 2.4,
            "acceptanceRadius": 1.2,
            "advanceOnSuccess": true,
            "mode": "loop"
          }
        }
      ],
      "transitions": [
        {
          "to": "Enraged",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "enraged",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Attack",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "hasLineOfSight",
              "op": "equals",
              "value": true
            },
            {
              "kind": "blackboard",
              "key": "inAttackRange",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Chase",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "hasLineOfSight",
              "op": "equals",
              "value": true
            }
          ]
        }
      ]
    },
    {
      "id": "Chase",
      "tasks": [
        {
          "task": "forge.setBlackboard",
          "params": {
            "key": "bossPhase",
            "value": "chase"
          }
        },
        {
          "task": "forge.moveToBlackboard",
          "params": {
            "key": "liveTargetPosition",
            "speed": 5,
            "acceptanceRadius": 1.4
          }
        }
      ],
      "transitions": [
        {
          "to": "Enraged",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "enraged",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Attack",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "inAttackRange",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Investigate",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "hasLineOfSight",
              "op": "equals",
              "value": false
            },
            {
              "kind": "blackboard",
              "key": "lastKnownTargetPosition",
              "op": "isSet"
            }
          ]
        }
      ]
    },
    {
      "id": "Attack",
      "tasks": [
        {
          "task": "forge.setBlackboard",
          "params": {
            "key": "bossPhase",
            "value": "attack"
          }
        },
        {
          "task": "forge.stopMovement"
        },
        {
          "task": "forge.sendMessage",
          "params": {
            "type": "boss.attack.intent",
            "cooldownSeconds": 0.9,
            "payload": {
              "attack": "punch",
              "animation": "Punch",
              "phase": "attack"
            }
          }
        }
      ],
      "transitions": [
        {
          "to": "Enraged",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "enraged",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Chase",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "inAttackRange",
              "op": "equals",
              "value": false
            }
          ]
        }
      ]
    },
    {
      "id": "Investigate",
      "tasks": [
        {
          "task": "forge.setBlackboard",
          "params": {
            "key": "bossPhase",
            "value": "investigate"
          }
        },
        {
          "task": "forge.moveToBlackboard",
          "params": {
            "key": "lastKnownTargetPosition",
            "speed": 3.6,
            "acceptanceRadius": 1.2
          }
        }
      ],
      "transitions": [
        {
          "to": "Enraged",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "enraged",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Chase",
          "conditions": [
            {
              "kind": "blackboard",
              "key": "hasLineOfSight",
              "op": "equals",
              "value": true
            }
          ]
        },
        {
          "to": "Patrol",
          "event": "investigation-complete"
        }
      ]
    },
    {
      "id": "Enraged",
      "enter": [
        {
          "kind": "blackboard",
          "key": "enraged",
          "op": "equals",
          "value": true
        }
      ],
      "tasks": [
        {
          "task": "forge.setBlackboard",
          "params": {
            "key": "bossPhase",
            "value": "enraged"
          }
        },
        {
          "task": "forge.sendMessage",
          "params": {
            "type": "boss.phase.changed",
            "payload": {
              "phase": "enraged",
              "music": "boss-high"
            }
          }
        },
        {
          "task": "forge.moveToBlackboard",
          "params": {
            "key": "liveTargetPosition",
            "speed": 6.5,
            "acceptanceRadius": 1.8
          }
        }
      ],
      "transitions": [
        {
          "to": "Patrol",
          "event": "boss-reset"
        }
      ]
    }
  ]
}
