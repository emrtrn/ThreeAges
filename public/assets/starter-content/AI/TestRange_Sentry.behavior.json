{
  "schema": 1,
  "type": "behaviorTree",
  "blackboard": "assets/starter-content/AI/TestRange_Sentry.blackboard.json",
  "root": {
    "id": "sentry-root",
    "kind": "selector",
    "services": [
      {
        "service": "forge.updatePerceptionBlackboard",
        "interval": 0.1,
        "params": {
          "targetKey": "target",
          "hasLineOfSightKey": "hasLineOfSight",
          "lastKnownPositionKey": "lastKnownTargetPosition"
        }
      }
    ],
    "children": [
      {
        "id": "sentry-alert-when-seen",
        "kind": "sequence",
        "decorators": [
          {
            "kind": "blackboard",
            "key": "hasLineOfSight",
            "op": "equals",
            "value": true
          }
        ],
        "children": [
          {
            "id": "sentry-state-alert",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "sightState",
              "value": "alert"
            }
          },
          {
            "id": "sentry-alert-hold",
            "kind": "wait",
            "seconds": 0.2
          }
        ]
      },
      {
        "id": "sentry-search-last-known",
        "kind": "sequence",
        "decorators": [
          {
            "kind": "blackboard",
            "key": "lastKnownTargetPosition",
            "op": "isSet"
          },
          {
            "kind": "blackboard",
            "key": "hasLineOfSight",
            "op": "equals",
            "value": false
          }
        ],
        "children": [
          {
            "id": "sentry-state-search",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "sightState",
              "value": "search"
            }
          },
          {
            "id": "sentry-search-linger",
            "kind": "wait",
            "seconds": 3
          },
          {
            "id": "sentry-clear-last-known",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "lastKnownTargetPosition",
              "value": null
            }
          },
          {
            "id": "sentry-clear-target",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "target",
              "value": null
            }
          }
        ]
      },
      {
        "id": "sentry-idle-at-post",
        "kind": "sequence",
        "children": [
          {
            "id": "sentry-state-idle",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "sightState",
              "value": "idle"
            }
          },
          {
            "id": "sentry-idle-hold",
            "kind": "wait",
            "seconds": 0.2
          }
        ]
      }
    ]
  }
}
