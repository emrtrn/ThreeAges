{
  "schema": 1,
  "type": "behaviorTree",
  "blackboard": "assets/starter-content/AI/AI_Test.blackboard.json",
  "root": {
    "id": "ai-test-root",
    "kind": "selector",
    "services": [
      {
        "service": "forge.updatePerceptionBlackboard",
        "interval": 0.1,
        "params": {
          "targetKey": "target",
          "hasLineOfSightKey": "hasLineOfSight",
          "lastKnownPositionKey": "lastKnownTargetPosition"
        }
      },
      {
        "service": "forge.updateTargetDistanceBlackboard",
        "interval": 0.05,
        "params": {
          "targetKey": "target",
          "distanceKey": "targetDistance",
          "inRangeKey": "inAttackRange",
          "targetPositionKey": "liveTargetPosition",
          "range": 2.4
        }
      }
    ],
    "children": [
      {
        "id": "attack-when-close",
        "kind": "sequence",
        "decorators": [
          {
            "kind": "blackboard",
            "key": "hasLineOfSight",
            "op": "equals",
            "value": true
          },
          {
            "kind": "blackboard",
            "key": "inAttackRange",
            "op": "equals",
            "value": true
          }
        ],
        "children": [
          {
            "id": "state-attack",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "combatState",
              "value": "attack"
            }
          },
          {
            "id": "emit-punch-intent",
            "kind": "task",
            "task": "forge.sendMessage",
            "params": {
              "type": "ai.attack.intent",
              "payload": {
                "attack": "punch",
                "animation": "punch"
              }
            }
          },
          {
            "id": "attack-cooldown",
            "kind": "wait",
            "seconds": 0.55
          }
        ]
      },
      {
        "id": "chase-visible-target",
        "kind": "sequence",
        "decorators": [
          {
            "kind": "blackboard",
            "key": "hasLineOfSight",
            "op": "equals",
            "value": true
          }
        ],
        "children": [
          {
            "id": "state-chase",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "combatState",
              "value": "chase"
            }
          },
          {
            "id": "move-to-live-target",
            "kind": "task",
            "task": "forge.moveToBlackboard",
            "params": {
              "key": "liveTargetPosition",
              "speed": 5.5,
              "acceptanceRadius": 1.2
            }
          }
        ]
      },
      {
        "id": "investigate-last-known",
        "kind": "sequence",
        "decorators": [
          {
            "kind": "blackboard",
            "key": "lastKnownTargetPosition",
            "op": "isSet"
          },
          {
            "kind": "blackboard",
            "key": "hasLineOfSight",
            "op": "equals",
            "value": false
          }
        ],
        "children": [
          {
            "id": "state-investigate",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "combatState",
              "value": "investigate"
            }
          },
          {
            "id": "move-to-last-known",
            "kind": "task",
            "task": "forge.moveToBlackboard",
            "params": {
              "key": "lastKnownTargetPosition",
              "speed": 4.2,
              "acceptanceRadius": 1
            }
          },
          {
            "id": "pause-at-last-known",
            "kind": "wait",
            "seconds": 0.2
          },
          {
            "id": "clear-last-known",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "lastKnownTargetPosition",
              "value": null
            }
          }
        ]
      },
      {
        "id": "patrol-loop",
        "kind": "sequence",
        "children": [
          {
            "id": "state-patrol",
            "kind": "task",
            "task": "forge.setBlackboard",
            "params": {
              "key": "combatState",
              "value": "patrol"
            }
          },
          {
            "id": "pick-patrol-target",
            "kind": "task",
            "task": "forge.setPatrolTarget",
            "params": {
              "key": "currentPatrolTarget",
              "positionKey": "patrolTargetPosition"
            }
          },
          {
            "id": "move-to-patrol-target",
            "kind": "task",
            "task": "forge.moveToPatrolTarget",
            "params": {
              "key": "currentPatrolTarget",
              "speed": 2.2,
              "acceptanceRadius": 0.9
            }
          },
          {
            "id": "wait-at-patrol-target",
            "kind": "wait",
            "seconds": 0.35
          },
          {
            "id": "advance-patrol-target",
            "kind": "task",
            "task": "forge.advancePatrolTarget",
            "params": {
              "key": "currentPatrolTarget",
              "mode": "loop"
            }
          }
        ]
      }
    ]
  }
}
