{
  "schema": 1,
  "type": "ui",
  "name": "Graphics Settings",
  "preview": {
    "width": 1280,
    "height": 720
  },
  "initialFocus": "back",
  "transition": {
    "enter": "fade",
    "exit": "fade",
    "durationMs": 120
  },
  "root": {
    "id": "root",
    "widget": "Canvas",
    "props": {
      "align": "center",
      "justify": "center",
      "padding": 24,
      "background": "rgba(4, 6, 10, 0.42)"
    },
    "children": [
      {
        "id": "panel",
        "widget": "Panel",
        "props": {
          "width": 560,
          "padding": 20,
          "gap": 14,
          "background": "rgba(16, 19, 26, 0.92)",
          "radius": 6
        },
        "children": [
          {
            "id": "title",
            "widget": "Text",
            "props": {
              "text": "Graphics",
              "fontSize": 24,
              "fontWeight": "700"
            }
          },
          {
            "id": "quality-group",
            "widget": "Stack",
            "props": {
              "direction": "column",
              "gap": 8,
              "padding": 12,
              "background": "rgba(255, 255, 255, 0.07)",
              "radius": 6
            },
            "children": [
              {
                "id": "quality-label",
                "widget": "Text",
                "props": {
                  "text": {
                    "bind": "graphics.qualityLabel"
                  },
                  "fontWeight": "700"
                }
              },
              {
                "id": "quality-actions",
                "widget": "Stack",
                "props": {
                  "direction": "row",
                  "gap": 8
                },
                "children": [
                  {
                    "id": "quality-ultra",
                    "widget": "Button",
                    "props": {
                      "text": "Ultra",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:quality:ultra"
                      }
                    }
                  },
                  {
                    "id": "quality-high",
                    "widget": "Button",
                    "props": {
                      "text": "High",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:quality:high"
                      }
                    }
                  },
                  {
                    "id": "quality-medium",
                    "widget": "Button",
                    "props": {
                      "text": "Medium",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:quality:medium"
                      }
                    }
                  },
                  {
                    "id": "quality-low",
                    "widget": "Button",
                    "props": {
                      "text": "Low",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:quality:low"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "adaptive-group",
            "widget": "Stack",
            "props": {
              "direction": "column",
              "gap": 8,
              "padding": 12,
              "background": "rgba(255, 255, 255, 0.07)",
              "radius": 6
            },
            "children": [
              {
                "id": "adaptive-label",
                "widget": "Text",
                "props": {
                  "text": {
                    "bind": "graphics.adaptiveLabel"
                  },
                  "fontWeight": "700"
                }
              },
              {
                "id": "adaptive-actions",
                "widget": "Stack",
                "props": {
                  "direction": "row",
                  "gap": 8
                },
                "children": [
                  {
                    "id": "adaptive-on",
                    "widget": "Button",
                    "props": {
                      "text": "On",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:adaptive:on"
                      }
                    }
                  },
                  {
                    "id": "adaptive-off",
                    "widget": "Button",
                    "props": {
                      "text": "Off",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:adaptive:off"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "targetfps-group",
            "widget": "Stack",
            "props": {
              "direction": "column",
              "gap": 8,
              "padding": 12,
              "background": "rgba(255, 255, 255, 0.07)",
              "radius": 6
            },
            "children": [
              {
                "id": "targetfps-label",
                "widget": "Text",
                "props": {
                  "text": {
                    "bind": "graphics.targetFpsLabel"
                  },
                  "fontWeight": "700"
                }
              },
              {
                "id": "targetfps-actions",
                "widget": "Stack",
                "props": {
                  "direction": "row",
                  "gap": 8
                },
                "children": [
                  {
                    "id": "targetfps-60",
                    "widget": "Button",
                    "props": {
                      "text": "60 FPS",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:targetfps:60"
                      }
                    }
                  },
                  {
                    "id": "targetfps-30",
                    "widget": "Button",
                    "props": {
                      "text": "30 FPS",
                      "onClick": {
                        "type": "message",
                        "message": "settings:graphics:targetfps:30"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "status",
            "widget": "Text",
            "props": {
              "text": {
                "bind": "graphics.status"
              },
              "fontSize": 13,
              "color": "#aab4c4"
            }
          },
          {
            "id": "footer",
            "widget": "Stack",
            "props": {
              "direction": "row",
              "justify": "end",
              "gap": 8
            },
            "children": [
              {
                "id": "reset",
                "widget": "Button",
                "props": {
                  "text": "Restore Defaults",
                  "onClick": {
                    "type": "message",
                    "message": "settings:graphics:reset"
                  }
                }
              },
              {
                "id": "back",
                "widget": "Button",
                "props": {
                  "text": "Back",
                  "onClick": {
                    "type": "back"
                  }
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
