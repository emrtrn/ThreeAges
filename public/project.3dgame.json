{
  "schema": 1,
  "name": "forge-template",
  "type": "three-game",
  "version": "0.1.0",
  "entry": "src/main.ts",
  "publicDir": "public",
  "editor": {
    "defaultScene": "assets/starter-content/Levels/AITestLevel.level.json",
    "assetManifest": "assets/manifest.json",
    "gridSize": 0.25,
    "gridEnabled": false,
    "snapRotationDeg": 15,
    "snapRotationEnabled": true,
    "snapScale": 0.1,
    "snapScaleEnabled": true
  },
  "scripts": {
    "preview": "npm run dev",
    "build": "npm run build",
    "package": "npm run build"
  },
  "output": {
    "distDir": "dist"
  }
}
