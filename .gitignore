# Dependencies & build output (Vite + TS skeleton lands in H1)
node_modules/
dist/
builds/
.dev-server/
*.local

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# OS
Thumbs.db
.DS_Store

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json

# Raw/unprocessed asset sources (processed assets live in public/assets/ with manifest)
tools/raw-assets/

# Generated asset-library index — heavy, machine-specific, regenerable via
# `node tools/asset-library-index.mjs`. The grep-friendly TSV + human catalog
# are kept tracked; only the full JSON is ignored.
tools/*/[!.]*-index.json
